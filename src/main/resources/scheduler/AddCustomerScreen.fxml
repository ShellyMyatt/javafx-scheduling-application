<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="401.0" prefWidth="480.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="scheduler.controller.AddCustomerController">
   <children>
      <Label layoutX="181.0" layoutY="20.0" text="Add Customer">
         <font>
            <Font name="System Bold" size="15.0" />
         </font></Label>
      <Label layoutX="112.0" layoutY="74.0" text="Customer_ID" />
      <Label layoutX="130.0" layoutY="109.0" text="Name" />
      <Label layoutX="125.0" layoutY="144.0" text="Address" />
      <Label layoutX="125.0" layoutY="179.0" text="Country" />
      <Label layoutX="108.0" layoutY="214.0" text="State/Province" />
      <Label layoutX="114.0" layoutY="249.0" text="Postal Code" />
      <Label layoutX="106.0" layoutY="284.0" text="Phone Number" />
      <TextField fx:id="addCustomerID" disable="true" editable="false" layoutX="226.0" layoutY="70.0" text="Auto-Gen" />
      <TextField fx:id="addCustomerName" layoutX="226.0" layoutY="105.0" />
      <TextField fx:id="addCustomerAddress" layoutX="226.0" layoutY="140.0" />
      <TextField fx:id="addCustomerPostalCode" layoutX="226.0" layoutY="245.0" />
      <TextField fx:id="addCustomerPhoneNumber" layoutX="226.0" layoutY="280.0" />
      <Button layoutX="174.0" layoutY="329.0" mnemonicParsing="false" onAction="#addCustomerSaveButton" text="Save" />
      <Button layoutX="257.0" layoutY="329.0" mnemonicParsing="false" onAction="#addCustomerCancelButton" text="Cancel" />
      <ComboBox fx:id="modifyCustomerCountry" layoutX="226.0" layoutY="175.0" onAction="#loadStatesForSelectedCountry" prefWidth="150.0" />
      <ComboBox fx:id="modifyCustomerState" layoutX="226.0" layoutY="210.0" prefWidth="150.0" />


   </children>
</AnchorPane>
