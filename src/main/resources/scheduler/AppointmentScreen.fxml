<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="469.0" prefWidth="939.0" style="-fx-background-color: #013167;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="scheduler.controller.AppointmentController">
   <children>
      <AnchorPane layoutX="44.0" prefHeight="506.0" prefWidth="930.0" style="-fx-background-color: White;">
         <children>
            <Button layoutX="787.0" layoutY="410.0" mnemonicParsing="false" onAction="#signOutButton" style="-fx-background-color: #A7C7E7;" text="Sign Out" />
            <TableView fx:id="appointmentsTable" layoutX="14.0" layoutY="84.0" prefHeight="296.0" prefWidth="910.0">
              <columns>
                <TableColumn fx:id="appointmentIDCol" prefWidth="110.0" text="Appointment_ID" />
                <TableColumn fx:id="titleCol" prefWidth="54.0" text="Title" />
                  <TableColumn fx:id="descriptionCol" prefWidth="89.0" text="Description" />
                  <TableColumn fx:id="locationCol" prefWidth="72.0" text="Location" />
                  <TableColumn fx:id="contactsCol" prefWidth="75.0" text="Contacts" />
                  <TableColumn fx:id="typeCol" prefWidth="48.0" text="Type" />
                  <TableColumn fx:id="startDateTimeCol" prefWidth="144.0" text="Start Date and Time" />
                  <TableColumn fx:id="endDateTimeCol" prefWidth="139.0" text="End Date and Time" />
                  <TableColumn fx:id="customerIDCol" prefWidth="93.0" text="Customer_ID" />
                  <TableColumn fx:id="userIDCol" prefWidth="86.0" text="User_ID" />
              </columns>
            </TableView>
            <Label layoutX="22.0" layoutY="22.0" text="Appointments">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Button layoutX="14.0" layoutY="410.0" mnemonicParsing="false" onAction="#addAppointmentButton" style="-fx-background-color: #A7C7E7;" text="Add Appointment" />
            <Button layoutX="150.0" layoutY="410.0" mnemonicParsing="false" onAction="#modifyAppointmentButton" style="-fx-background-color: #A7C7E7;" text="Modify Appointment" />
            <Button layoutX="300.0" layoutY="410.0" mnemonicParsing="false" onAction="#deleteAppointmentButton" style="-fx-background-color: #A7C7E7;" text="Delete Appointment" />
            <Button layoutX="689.0" layoutY="410.0" mnemonicParsing="false" onAction="#reportsButton" text="Reports" />
            <Button layoutX="531.0" layoutY="410.0" mnemonicParsing="false" onAction="#viewCustomersButton" text="View and Edit Customers" />

            <RadioButton fx:id="allAppointmentsRadioButton" layoutX="285.0" layoutY="49.0" mnemonicParsing="false" onAction="#allAppointmentsOnAction" selected="true" text="All Appointments">
               <toggleGroup>
                  <ToggleGroup fx:id="appointmentRadioButtons" />
               </toggleGroup></RadioButton>

            <RadioButton fx:id="weeklyAppointmentsRadioButton" layoutX="424.0" layoutY="49.0" mnemonicParsing="false" onAction="#weekAppointmentsOnAction" text="Current Week's Appointments" toggleGroup="$appointmentRadioButtons" />
            <RadioButton fx:id="monthlyAppointmentsRadioButton" layoutX="633.0" layoutY="49.0" mnemonicParsing="false" onAction="#monthsAppointmentsOnAction" text="Current Month's Appointments" toggleGroup="$appointmentRadioButtons" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
