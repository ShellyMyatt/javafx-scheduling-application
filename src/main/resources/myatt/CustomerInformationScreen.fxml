<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="481.0" prefWidth="743.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="myatt.controller.CustomerInformationController">
   <children>
      <AnchorPane prefHeight="481.0" prefWidth="756.0">
         <children>
            <TableView fx:id="customerInformationTable" layoutX="34.0" layoutY="71.0" prefHeight="339.0" prefWidth="684.0">
              <columns>
                <TableColumn fx:id="customerIDCol" prefWidth="38.0" text="ID" />
                <TableColumn fx:id="customerNameCol" prefWidth="130.0" text="Name" />
                  <TableColumn fx:id="addressCol" prefWidth="171.0" text="Address" />
                  <TableColumn fx:id="postalCodeCol" prefWidth="86.0" text="Postal Code " />
                  <TableColumn fx:id="phoneNumberCol" prefWidth="141.0" text="Phone Number" />
