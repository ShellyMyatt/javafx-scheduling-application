              </columns>
            </TableView>
            <Button layoutX="34.0" layoutY="424.0" mnemonicParsing="false" onAction="#addCustomerButton" text="Add Customer" />
            <Button layoutX="147.0" layoutY="424.0" mnemonicParsing="false" onAction="#modifyCustomerButton" text="Modify Customer" />
            <Button layoutX="273.0" layoutY="424.0" mnemonicParsing="false" onAction="#deleteCustomerButton" text="Delete Customer" />
            <Button layoutX="467.0" layoutY="424.0" mnemonicParsing="false" onAction="#mainMenuButton" text="Main Menu" />
